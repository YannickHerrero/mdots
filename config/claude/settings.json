{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git commit:*)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(git cherry-pick *)",

      "Bash(find *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",

      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(jq *)",
      "Bash(xargs *)",

      "Bash(which *)",
      "Bash(command *)",
      "Bash(type *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(uname *)",
      "Bash(id)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(printf *)",

      "Bash(node -e *)",
      "Bash(node --eval *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(npm list *)",
      "Bash(npm view *)",
      "Bash(pnpm list *)",
      "Bash(pnpm view *)",

      "Bash(cargo check:*)",
      "Bash(cargo search:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",

      "Bash(npx tsc *)"
    ],
    "ask": [
      "Bash(sudo *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kubectl *)",
      "Bash(terraform *)",
      "Bash(npm install *)",
      "Bash(npm update *)",
      "Bash(pnpm add *)",
      "Bash(pnpm install *)",
      "Bash(yarn add *)",
      "Bash(yarn install *)",
      "Bash(bun add *)",
      "Bash(bun install *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./*.pem)",
      "Read(./*.key)"
    ],
    "defaultMode": "acceptEdits"
  },
  "autoUpdatesChannel": "stable",
  "includeGitInstructions": true,
  "respectGitignore": true,
  "showTurnDuration": true,
  "spinnerTipsEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 2
  }
}
